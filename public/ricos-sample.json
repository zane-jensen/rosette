                                },
                                {
                                    "id": "",
                                    "nodes": [],
                                    "textData": {
                                        "decorations": [],
                                        "text": ". Going forward, TechGenie will only support IOS versions 18+ or newer."
                                    },
                                    "type": "TEXT"
