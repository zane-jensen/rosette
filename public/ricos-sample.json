                                    "id": "",
                                    "nodes": [],
                                    "textData": {
                                        "decorations": [],
                                        "text": "Previously, if a customer made a payment that was greater than the Due at Install amount, TechGenie would display a negative amount. This made it seem as though a credit was owed, leading to misrepresentation and a poor experience for customers and pros."
                                    },
                                    "type": "TEXT"
                                }
                            ],
                            "type": "PARAGRAPH"
                        }
                    ],
                    "type": "LIST_ITEM"
                },
                {
