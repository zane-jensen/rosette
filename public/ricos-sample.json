                            "id": "nkvgo1378",
                            "nodes": [
                                {
                                    "id": "",
                                    "nodes": [],
                                    "textData": {
                                        "decorations": [],
                                        "text": "The Due at install now has a minimum of $0. This means it will no longer be possible for Order Summary to show negative Due at Install amounts regardless of prior payments taken."
                                    },
                                    "type": "TEXT"
                                }
                            ],
                            "type": "PARAGRAPH"
                        }
